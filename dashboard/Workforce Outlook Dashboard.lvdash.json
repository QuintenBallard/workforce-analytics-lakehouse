{
  "datasets": [
    {
      "name": "workforce_outlook",
      "displayName": "Workforce Outlook",
      "config": {
        "source": "workforce_analytics.gold.fact_occupation_projection",
        "measures": [
          {
            "displayName": "Total Base-Year Employment",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              },
              "abbreviation": "compact"
            },
            "name": "total_base_employment",
            "expr": "SUM(employment_base_year)",
            "comment": "Total employment in base year"
          },
          {
            "displayName": "Total Projected Employment",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              },
              "abbreviation": "compact"
            },
            "name": "total_projected_employment",
            "expr": "SUM(employment_projected_year)",
            "comment": "Total projected employment"
          },
          {
            "displayName": "Total Annual Openings",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              },
              "abbreviation": "compact"
            },
            "name": "total_annual_openings",
            "expr": "SUM(annual_openings)",
            "comment": "Total annual job openings"
          },
          {
            "displayName": "Average Median Annual Wage Across Occupations",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              }
            },
            "name": "avg_median_wage",
            "expr": "AVG(median_annual_wage)",
            "comment": "Average of median annual wages across occupations"
          }
        ],
        "filter": "occupation_type = 'Line item'",
        "version": "1.1",
        "comment": "Workforce occupation projections - detailed occupations only",
        "dimensions": [
          {
            "name": "occupation_title",
            "expr": "occupation_title",
            "displayName": "Occupation",
            "comment": "Occupation title"
          },
          {
            "name": "occupation_type",
            "expr": "occupation_type",
            "displayName": "Occupation Type",
            "comment": "Type of occupation"
          },
          {
            "name": "typical_entry_education",
            "expr": "typical_entry_education",
            "displayName": "Typical Entry Education",
            "comment": "Education level typically required for entry"
          },
          {
            "name": "growth_direction",
            "expr": "growth_direction",
            "displayName": "Growth Direction",
            "comment": "Direction of employment growth (Growing/Declining)"
          },
          {
            "name": "on_the_job_training",
            "expr": "on_the_job_training",
            "displayName": "On-the-Job Training",
            "comment": "Required on-the-job training"
          },
          {
            "displayName": "Employment Growth Rate",
            "format": {
              "type": "percentage",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            },
            "name": "employment_change_percent",
            "expr": "employment_change_percent",
            "comment": "Percentage change in employment"
          },
          {
            "displayName": "Median Annual Wage",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              }
            },
            "name": "median_annual_wage",
            "expr": "median_annual_wage",
            "comment": "Median annual wage for occupation"
          },
          {
            "name": "annual_openings",
            "expr": "annual_openings",
            "displayName": "Annual Openings",
            "comment": "Annual job openings for this occupation"
          }
        ]
      }
    }
  ],
